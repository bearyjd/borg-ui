{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-conf/main/schemas/tauri.conf.2.json",
  "productName": "BorgUI",
  "identifier": "com.borgui.app",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "BorgUI — Backup Manager",
        "width": 960,
        "height": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": []
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgzQTg0RTk0QkNEQTQzQ0MKUldUTVE5cThsRTZvZzR4ajNxZnhsM08xRFJscE5QdC9vUURGQkFuaE1jcm1HQ0Z0bE1HeHdBTVAK",
      "endpoints": [
        "https://github.com/bearyjd/borg-ui/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
